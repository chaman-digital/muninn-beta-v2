# ═══════════════════════════════════════════════════
#  MUNINN V1.3 — .gitignore
#  POLÍTICA: Solo trackear .py, .md, .json, .gitignore
#  Cualquier archivo >10MB que no sea .py o .md → EXCLUIDO
# ═══════════════════════════════════════════════════

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# ── Virtual Environments ──
.venv/
venv/
env/
.env

# ── Bases de Datos (NUNCA trackear) ──
*.db
*.db-journal
*.db-wal
*.sqlite
*.sqlite3
muninn_memory.db

# ── Multimedia pesada (>50MB posible) ──
*.m4a
*.mp3
*.wav
*.ogg
*.flac
*.mp4
*.mov
*.avi
*.mkv
*.heic

# ── Imágenes (evidencia — solo local) ──
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.tiff
*.bmp

# ── Documentos binarios pesados ──
*.pdf
*.docx
*.doc
*.xlsx
*.pptx

# ── Logs, dumps y archivos temporales ──
*.log
output.log
watchdog.pid
*.pid
*.tmp
*.bak
docx_dump.txt
pdf_text.txt
temp_*.txt
temp_*.json

# ── Carpetas de evidencia (solo local) ──
2021/
2022/
2023/
2024/
2025/
2026/
previo a 2015/
grabaciones de audio/
Documentos IO/
PAGOS PENSIÓN/
VLV/
legislacion/

# ── macOS ──
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Binarios y herramientas ──
cloudflared
.webui_secret_key

# ── Metadata generada (regenerable) ──
metadata_multimodal.json

# ── IDE ──
.idea/
.vscode/
*.swp
*.swo
*~
.venv/
muninn_memory.db
*.m4a
*.png
